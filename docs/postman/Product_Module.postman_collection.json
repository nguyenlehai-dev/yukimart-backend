{
  "info": {
    "name": "Yukimart - Full API",
    "description": "Postman collection day du cho du an Yukimart Backend. Bao gom tat ca API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "token", "value": "" },
    { "key": "org_id", "value": "1" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.add({ key: 'X-Organization-Id', value: pm.collectionVariables.get('org_id') });",
          "pm.request.headers.add({ key: 'Accept', value: 'application/json' });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["var r=pm.response.json();if(r.data&&r.data.access_token){pm.collectionVariables.set('token',r.data.access_token);} if(r.data&&r.data.current_organization_id){pm.collectionVariables.set('org_id',String(r.data.current_organization_id));}"] } }],
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"admin@example.com\",\"password\":\"quandcore**11\"}" }, "url": "{{base_url}}/auth/login" }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{base_url}}/auth/logout" }
        },
        {
          "name": "Me (thong tin user)",
          "request": { "method": "GET", "url": "{{base_url}}/user" }
        },
        {
          "name": "Switch Organization",
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"organization_id\":1}" }, "url": "{{base_url}}/auth/switch-organization" }
        },
        {
          "name": "Forgot Password",
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"admin@example.com\"}" }, "url": "{{base_url}}/auth/forgot-password" }
        },
        {
          "name": "Reset Password",
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"token\":\"xxx\",\"email\":\"admin@example.com\",\"password\":\"newpassword\",\"password_confirmation\":\"newpassword\"}" }, "url": "{{base_url}}/auth/reset-password" }
        }
      ]
    },
    {
