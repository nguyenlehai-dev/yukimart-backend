        { "name": "Xoa user", "request": { "method": "DELETE", "url": "{{base_url}}/users/1" } },
        { "name": "Bulk delete", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"ids\":[1,2]}" }, "url": "{{base_url}}/users/bulk-delete" } },
        { "name": "Bulk status", "request": { "method": "PATCH", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"ids\":[1,2],\"status\":\"active\"}" }, "url": "{{base_url}}/users/bulk-status" } },
        { "name": "Export", "request": { "method": "GET", "url": "{{base_url}}/users/export" } },
        { "name": "Import", "request": { "method": "POST", "body": { "mode": "formdata", "formdata": [{"key":"file","type":"file","src":""}] }, "url": "{{base_url}}/users/import" } }
