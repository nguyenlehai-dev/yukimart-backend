        { "name": "Tao user", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"name\":\"Test User\",\"email\":\"test@example.com\",\"password\":\"password\",\"password_confirmation\":\"password\"}" }, "url": "{{base_url}}/users" } },
        { "name": "Cap nhat user", "request": { "method": "PUT", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"name\":\"Test User Updated\"}" }, "url": "{{base_url}}/users/1" } },
